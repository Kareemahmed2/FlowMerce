# ── Required secrets (no defaults — app refuses to start without these) ────────
JWT_SECRET=          # generate: openssl rand -base64 48
DB_PASSWORD=         # your Supabase / Postgres password
MAIL_PASSWORD=       # your Gmail app password (Settings > Security > App passwords)
INTEGRATION_ENCRYPTION_KEY=   # generate: openssl rand -base64 32 — encrypts per-store Paymob/DHL/Aramex/Bosta credentials at rest

# ── Optional overrides ─────────────────────────────────────────────────────────
DB_URL=              # default: Supabase URL in application.properties
DB_USERNAME=         # default: postgres
MAIL_USERNAME=       # default: ka.mahrous@gmail.com

ADMIN_EMAIL=         # default: admin@flowmerce.com
ADMIN_PASSWORD=      # default: ChangeMe!2026  (MUST override with SPRING_PROFILES_ACTIVE=prod)

FRONTEND_URL=        # default: http://localhost:3000  (used in activation email links)

# ── Docker-compose service passwords (dev throwaway, override in prod) ─────────
RABBITMQ_PASSWORD=   # default: secret

# ── Social OAuth2 ─────────────────────────────────────────────────────────────
# Google: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:8080/api/v1/auth/social/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=   # optional — defaults to localhost:8080 callback above

# Facebook: https://developers.facebook.com/apps
# Valid OAuth Redirect URI: http://localhost:8080/api/v1/auth/social/facebook/callback
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
FACEBOOK_REDIRECT_URI= # optional — defaults to localhost:8080 callback above

# ── Optional API keys ──────────────────────────────────────────────────────────
GROQ_API_KEY=        # from https://console.groq.com/keys  (frontend AI assistant)

# ── Spring profile ─────────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=  # set to "prod" to enable SEC-7 admin-password guard