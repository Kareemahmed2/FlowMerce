# ── Backend API ───────────────────────────────────────────────────────────────
# Base URL of the Spring Boot backend (no trailing slash).
# Dev: http://localhost:8080/api/v1
# Docker: http://backend:8080/api/v1  (compose internal network)
# Prod: https://your-api.example.com/api/v1
NEXT_PUBLIC_API_URL=http://localhost:8080/api/v1

# ── Groq AI assistant (optional) ──────────────────────────────────────────────
# Get a free key at https://console.groq.com/keys
# Never commit a real key — this file is gitignored.
GROQ_API_KEY=
