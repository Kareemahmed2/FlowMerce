{
  "info": {
    "_postman_id": "flowmerce-api-v1",
    "name": "FlowMerce API",
    "description": "FlowMerce Backend API — base URL: {{baseUrl}} = http://localhost:8080/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl",      "value": "http://localhost:8080/api/v1" },
    { "key": "accessToken",  "value": "" },
    { "key": "refreshToken", "value": "" },
    { "key": "storeId",      "value": "1" },
    { "key": "storeUrl",     "value": "my-store" }
  ],
  "item": [

    {
      "name": "Auth — Merchant",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/register", "host": ["{{baseUrl}}"], "path": ["auth","merchant","register"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"Password123!\",\n  \"fullName\": \"Ahmed Mohamed\",\n  \"phone\": \"01012345678\"\n}" }
          }
        },
        {
          "name": "Activate Account",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/auth/merchant/activate?token=REPLACE_WITH_TOKEN", "host": ["{{baseUrl}}"], "path": ["auth","merchant","activate"], "query": [{ "key": "token", "value": "REPLACE_WITH_TOKEN" }] }
          }
        },
        {
          "name": "Login",
          "event": [{ "listen": "test", "script": { "exec": ["var json = pm.response.json();", "if (json.data) {", "  pm.collectionVariables.set('accessToken', json.data.accessToken);", "  pm.collectionVariables.set('refreshToken', json.data.refreshToken);", "}"], "type": "text/javascript" } }],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/login", "host": ["{{baseUrl}}"], "path": ["auth","merchant","login"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"merchant@example.com\",\n  \"password\": \"Password123!\"\n}" }
          }
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/refresh", "host": ["{{baseUrl}}"], "path": ["auth","merchant","refresh"] },
            "body": { "mode": "raw", "raw": "{\n  \"refreshToken\": \"{{refreshToken}}\"\n}" }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/me", "host": ["{{baseUrl}}"], "path": ["auth","merchant","me"] }
          }
        },
        {
          "name": "Forgot Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/forgot-password", "host": ["{{baseUrl}}"], "path": ["auth","merchant","forgot-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"merchant@example.com\"\n}" }
          }
        },
        {
          "name": "Reset Password",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/reset-password", "host": ["{{baseUrl}}"], "path": ["auth","merchant","reset-password"] },
            "body": { "mode": "raw", "raw": "{\n  \"token\": \"REPLACE_WITH_TOKEN\",\n  \"newPassword\": \"NewPassword123!\",\n  \"confirmNewPassword\": \"NewPassword123!\"\n}" }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": { "raw": "{{baseUrl}}/auth/merchant/logout", "host": ["{{baseUrl}}"], "path": ["auth","merchant","logout"] }
          }
        }
      ]
    },

