{"nodes": [{"id": "pdf_FlowMerceMidyearDoc", "label": "FlowMerce Midyear Documentation (FCI-CU GP 2025)", "file_type": "paper", "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": null, "source_url": null, "captured_at": null, "author": "Kareem Ahmed Mahrous, Jana Mohamed Salem, Farah Mahmoud Hassaan, Bahaa Mohamed Akl, Hana Abdelbari Elsayed", "contributor": "Prof. Khaled Wassif, Dr. Rasha ElBanna, TA. Menna Youssef"}, {"id": "rationale_microservices_arch", "label": "Microservices Architecture Rationale", "file_type": "rationale", "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 5, System Architecture", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "FlowMerce uses microservices for security isolation, scalability, and reliability. Each service owns its business logic and data (loose coupling, high cohesion). API Gateway handles JWT validation, routing, rate limiting, and hides internal services."}, {"id": "concept_rbac", "label": "Role-Based Access Control (RBAC)", "file_type": "rationale", "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 3, Main Techniques", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "RBAC manages permissions for users, merchants, admins, and system services. Roles: MERCHANT, BUYER (CUSTOMER), ADMIN. Enforced via Spring Security @PreAuthorize and JWT claims."}, {"id": "concept_jwt_auth", "label": "JWT-Based Authentication", "file_type": "rationale", "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 3, Main Techniques", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "JWT ensures secure stateless user sessions. Access tokens + refresh tokens stored in sessions table with revocation support. JwtAuthFilter validates tokens on every request before UsernamePasswordAuthenticationFilter."}, {"id": "concept_ai_assistant", "label": "AI-Powered UX/UI Advisor", "file_type": "rationale", "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 7, Requirement 6", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Core differentiator: AI assistant analyzes storefront layout and provides explainable, optional recommendations for color palette, visual hierarchy, typography, accessibility. Integrates with OpenAI/DeepSeek API. Merchants can accept or reject suggestions."}], "edges": [{"source": "pdf_FlowMerceMidyearDoc", "target": "concept_ai_assistant", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 7, Requirement 6", "weight": 1.0}, {"source": "pdf_FlowMerceMidyearDoc", "target": "concept_rbac", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 3, Main Techniques", "weight": 1.0}, {"source": "pdf_FlowMerceMidyearDoc", "target": "concept_jwt_auth", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 3, Main Techniques", "weight": 1.0}, {"source": "pdf_FlowMerceMidyearDoc", "target": "rationale_microservices_arch", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 5, System Architecture", "weight": 1.0}, {"source": "pdf_FlowMerceMidyearDoc", "target": "storefrontcustomizationcontroller_StorefrontCustomizationController", "relation": "references", "confidence": "INFERRED", "confidence_score": 0.85, "source_file": "Copy of FCI-CU-GP-Midyear-Document-2025.pdf", "source_location": "Page 7, Requirement 5", "weight": 1.0}, {"source": 