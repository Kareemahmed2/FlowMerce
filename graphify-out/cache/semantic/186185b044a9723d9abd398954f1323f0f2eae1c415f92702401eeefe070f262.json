{"nodes": [{"id": "paymentreport_PaymentServiceReport", "label": "Payment Service Development Report", "file_type": "document", "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": null, "source_url": null, "captured_at": null, "author": null, "contributor": null}, {"id": "rationale_gateway_strategy", "label": "Gateway Adapter Strategy Pattern Rationale", "file_type": "rationale", "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.1", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Six adapters implement PaymentGatewayAdapter via the Strategy pattern. Spring injects List<PaymentGatewayAdapter>; service calls adapter.supports(). Adding a new gateway requires only implementing the interface \u2014 no service changes. Ensures loose coupling and open/closed principle."}, {"id": "rationale_idempotency_redis", "label": "Redis Idempotency Key Rationale", "file_type": "rationale", "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.2", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Payment requests carry an idempotencyKey (UUID). Redis caches {paymentId, status} for 24h TTL. DB has UNIQUE constraint as second safety net. Prevents double charges on network retries without distributed locking overhead."}, {"id": "rationale_wallet_simulation", "label": "Wallet Simulation for Demo Rationale", "file_type": "rationale", "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.3", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Customer wallet seeded with 100,000 EGP; merchant wallet starts at 0. Used for demo/presentation purposes. Eliminates need to configure real payment gateways during development while fully exercising the payment flow."}, {"id": "concept_rabbitmq_events", "label": "RabbitMQ Asynchronous Event Bus", "file_type": "rationale", "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.4", "source_url": null, "captured_at": null, "author": null, "contributor": null, "rationale": "Exchange: flowmerce.payment (topic). Queues: payment.notifications (binds payment.* and wallet.*) and payment.webhooks. Publish failure is non-critical \u2014 logs warning but does not roll back transaction. Decouples payment processing from notification delivery."}], "edges": [{"source": "paymentreport_PaymentServiceReport", "target": "paymentserviceimpl_PaymentServiceImpl", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2, Section 6", "weight": 1.0}, {"source": "paymentreport_PaymentServiceReport", "target": "walletsimulationadapter_WalletSimulationAdapter", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.1, Table row 1", "weight": 1.0}, {"source": "paymentreport_PaymentServiceReport", "target": "concept_rabbitmq_events", "relation": "references", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.4", "weight": 1.0}, {"source": "paymentreport_PaymentServiceReport", "target": "rationale_gateway_strategy", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.1", "weight": 1.0}, {"source": "paymentreport_PaymentServiceReport", "target": "rationale_idempotency_redis", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PAYMENT_SERVICE_REPORT.md", "source_location": "Section 2.2", "weight": 1.0}, {"source": "rationale_gateway_strategy", "target": "walletsimulationadapter_WalletSimulationAdapter", "relation": "rationale_for", "confidence": "EXTRACTED", "confidence_score": 1.0, "source_file": "PAYMENT_SERVICE_REPORT